# Supabase public frontend config
# Copy to .env.local for local cloud testing. Do not commit .env.local.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# GitHub Pages project-site base path. Local dev can leave this as /.
# GitHub Actions sets this automatically to /<repo-name>/.
VITE_BASE_PATH=/
